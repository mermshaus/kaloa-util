{
    "name": "kaloa/util",
    "type": "library",
    "description": "A collection of utility classes",
    "keywords": ["util"],
    "license": "MIT",
    "authors": [
        {
            "name": "Marc Ermshaus",
            "email": "marc@ermshaus.org",
            "homepage": "https://www.ermshaus.org/"
        }
    ],
    "require": {
        "php": ">=8.2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "squizlabs/php_codesniffer": "^4.0",
        "phpmd/phpmd": "~2.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Kaloa\\Util\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kaloa\\Tests\\Util\\": "tests"
        }
    }
}
